{
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(op run*)",
      "Bash(ls*)",
      "Bash(mkdir*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/review-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
